{
  "private": true,
  "repository": "arianrhodsandlot/retroassembly",
  "type": "module",
  "imports": {
    "#@/*": "./src/*"
  },
  "scripts": {
    "build": "react-router build",
    "build:node": "node --run=build",
    "build:workerd": "node --run=build",
    "check-lockfile": "node scripts/check-lockfile.ts",
    "dev": "react-router dev",
    "dev:node": "node --run=dev",
    "dev:test": "node --run=test -- --headed --ui",
    "dev:workerd": "node --run=dev",
    "lint": "vp check",
    "serve": "node dist/server/serve.js",
    "serve:node": "node --run=serve",
    "serve:workerd": "wrangler dev --port=8000",
    "setup": "node scripts/setup.ts",
    "start": "node --run=serve",
    "tag": "node scripts/tag.ts",
    "test": "playwright test -c tests/e2e --tsconfig=tests/e2e/tsconfig.playwright.json"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "hono": "4.12.27"
